generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  WONT_DO
}

model Board {
  id          String   @id @default(uuid())
  name        String
  description String?
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String     @id @default(uuid())
  boardId     String
  board       Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?
  status      TaskStatus @default(TODO)
  order       Int        @default(0)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([boardId])
  @@index([status])
}